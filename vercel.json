{
  "version": 2,
  "builds": [
    {
      "src": "app-francos/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "app-francos/dist/app-francos"
      }
    }
  ],  "outputDirectory": "app-francos/dist/app-francos",  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
