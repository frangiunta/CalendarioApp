{
  "version": 2,
  "builds": [
    {
      "src": "app-francos/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/browser"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "app-francos/dist/$1"
    }
  ]
}
